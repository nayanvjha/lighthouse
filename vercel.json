{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "redirects": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "nayanvjha.dev"
        }
      ],
      "destination": "https://www.nayanvjha.dev/$1",
      "permanent": true
    }
  ]
}
